<%- include('partials/header') %>
<div class="page-header"><div><div class="page-title">Search</div><div class="page-sub">Full-text, metadata & filters</div></div></div>
<div class="card" style="margin-bottom:16px">
  <form method="GET" action="/search" style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr auto;gap:10px;align-items:end">
    <div><label>Query</label><input type="text" name="q" value="<%= query.q||'' %>" placeholder="Name, CID, doc number..."/></div>
    <div><label>Type</label><select name="type"><option value="">All</option><option <%= query.type==='Passport'?'selected':'' %>>Passport</option><option <%= query.type==='National ID'?'selected':'' %>>National ID</option><option <%= query.type==='Loan Application'?'selected':'' %>>Loan Application</option><option <%= query.type==='Contract'?'selected':'' %>>Contract</option></select></div>
    <div><label>Status</label><select name="status"><option value="">All</option><option <%= query.status==='Valid'?'selected':'' %>>Valid</option><option <%= query.status==='Expiring'?'selected':'' %>>Expiring</option><option <%= query.status==='Expired'?'selected':'' %>>Expired</option></select></div>
    <div><label>Branch</label><select name="branch"><option value="">All</option><option>Cairo West</option><option>Alexandria HQ</option><option>Giza</option><option>Cairo East</option></select></div>
    <button class="btn btn-primary" type="submit">Search</button>
  </form>
</div>
<div class="card">
  <div class="card-header">Results <span style="color:var(--silver);font-weight:400"><%= results.length %> found</span></div>
  <table><thead><tr><th>Document</th><th>Customer</th><th>Type</th><th>Expiry</th><th>Status</th></tr></thead><tbody>
  <% results.forEach(d => { %>
    <tr><td><a href="/documents/viewer/<%= d.id %>" style="color:var(--gold2)"><%= d.original_name %></a></td><td><%= d.customer_name||'-' %></td><td><%= d.doc_type||'-' %></td><td><%= d.expiry_date||'-' %></td><td><span class="tag tag-<%= d.status==='Valid'?'success':(d.status==='Expired'?'danger':'warn') %>"><%= d.status %></span></td></tr>
  <% }) %>
  <% if (results.length === 0) { %><tr><td colspan="5" style="text-align:center;color:var(--silver);padding:30px">Enter a query to search</td></tr><% } %>
  </tbody></table>
</div>
<%- include('partials/footer') %>
