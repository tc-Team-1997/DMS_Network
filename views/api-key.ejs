<%- include('partials/header') %>
<div class="page-header"><div><div class="page-title">API Key</div><div class="page-sub">Store this now — it won't be shown again</div></div></div>
<div class="card">
  <div class="card-header">Your API Key</div>
  <div style="font-family:monospace;background:rgba(0,0,0,.2);padding:14px;border-radius:8px;word-break:break-all;color:var(--gold2)"><%= key %></div>
  <div class="divider"></div>
  <div class="card-header" style="font-size:12px">Usage</div>
  <pre style="background:rgba(0,0,0,.2);padding:12px;border-radius:8px;font-size:12px;color:var(--light);overflow-x:auto">curl -H "x-api-key: <%= key %>" http://localhost:3000/api/v1/documents
curl -H "x-api-key: <%= key %>" http://localhost:3000/api/v1/stats</pre>
  <a href="/admin/security" class="btn btn-secondary" style="margin-top:12px">Back</a>
</div>
<%- include('partials/footer') %>
