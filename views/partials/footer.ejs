  </div>
</div>
<div id="toast-stack" style="position:fixed;bottom:20px;right:20px;display:flex;flex-direction:column;gap:8px;z-index:9999"></div>
<script>
(function(){
  try {
    const proto = location.protocol === 'https:' ? 'wss' : 'ws';
    const sock = new WebSocket(proto + '://' + location.host + '/ws');
    sock.onmessage = (ev) => {
      let p; try { p = JSON.parse(ev.data); } catch(e){ return; }
      if (p.type === 'hello') return;
      const div = document.createElement('div');
      const color = p.type === 'alert' && p.level === 'critical' ? '#e05c5c' : (p.type === 'workflow' || p.type === 'workflow-update' ? '#c9a84c' : '#4a9fd4');
      div.style.cssText = 'background:#0f2044;border:1px solid '+color+';border-left:4px solid '+color+';padding:12px 16px;border-radius:8px;color:#e8eef6;font-size:12px;min-width:260px;max-width:360px;box-shadow:0 4px 12px rgba(0,0,0,.4);animation:slideIn .3s ease';
      div.innerHTML = '<div style="font-weight:600;color:'+color+';margin-bottom:4px;text-transform:uppercase;font-size:10px;letter-spacing:1px">'+p.type+'</div>'+(p.title||p.message||JSON.stringify(p));
      document.getElementById('toast-stack').appendChild(div);
      setTimeout(() => { div.style.opacity = '0'; div.style.transition = 'opacity .4s'; setTimeout(()=>div.remove(), 400); }, 6000);
    };
  } catch(e) { console.log('WS unavailable'); }
})();
</script>
<style>@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}</style>
</body>
</html>
