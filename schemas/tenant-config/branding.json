{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tenant-config/branding",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {
    "primary_color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "monogram": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8
    },
    "logo_path": {
      "type": "string"
    },
    "favicon_path": {
      "type": "string"
    },
    "login_banner": {
      "type": "string"
    },
    "footer_text": {
      "type": "string"
    }
  }
}
