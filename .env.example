# Node gateway environment variables
# Copy to .env and adjust values before running locally.

# ---- Session store ----
# Redis is OPTIONAL for local development.  When unset, the Node gateway uses
# an in-process MemoryStore (sessions are lost on restart, no per-user tracking).
# To enable durable sessions + the /spa/api/auth/active-sessions endpoint:
#   brew install redis && brew services start redis
# Then set:
REDIS_URL=redis://localhost:6379/0

# Session lifetime tuning
SESSION_TTL_SECONDS=7200      # 2 hours — full session lifetime
SESSION_EXTEND_SECONDS=3600   # +1 hour added by the extend-session endpoint
SESSION_WARNING_SECONDS=1800  # 30 minutes — SPA shows the countdown banner below this

# Change this to a long random string in production.
SESSION_SECRET=change-me-in-prod

# ---- Python microservice ----
PYTHON_SERVICE_URL=http://localhost:8001
PYTHON_SERVICE_KEY=dev-key-change-me

# ---- Node port ----
PORT=3000
NODE_ENV=development
